# Dependencies (reinstalled in container)
node_modules
.pnpm-store

# Build outputs (rebuilt in container)
.next
.open-next
dist

# Version control & CI
.git
.github
.gitignore

# Cloudflare / local dev state
.wrangler
.source

# Environment & secrets
.env*

# IDE & editor
.vscode
.idea
.DS_Store
Thumbs.db
.cursorrules

