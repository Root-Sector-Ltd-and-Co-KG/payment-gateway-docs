{
  "name": "payment-gateway-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "types:check": "pnpm typecheck",
    "secrets:push": "pnpm secrets:push:production",
    "secrets:check": "pnpm secrets:check:production",
    "secrets:push:production": "node scripts/push-cloudflare-secrets.mjs --env production --file .cloudflare-secrets.local",
    "secrets:check:production": "node scripts/push-cloudflare-secrets.mjs --env production --file .cloudflare-secrets.local --dry-run",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf:production": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "validate": "pnpm typecheck && pnpm build",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@takumi-rs/image-response": "^0.71.7",
    "dotenv": "^17.3.1",
    "fumadocs-core": "16.6.16",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.16",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.72.0"
  }
}
