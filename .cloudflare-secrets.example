# Local Cloudflare credentials for payment-gateway-docs deployments.
# Copy this file to .cloudflare-secrets.local and fill in real values.
#
# These credentials are used by Wrangler for local preview and production
# deployment commands. Add any additional non-empty variables below these
# credentials to upload them as Worker runtime secrets with `pnpm secrets:push`.

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=